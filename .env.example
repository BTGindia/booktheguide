# Book The Guide - Environment Variables

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/booktheguide?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Book The Guide"

# Email (for booking confirmations - configure later)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=

# Payment (configure later)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# File Upload (configure later)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Google Gemini AI (for NEEV AI Travel Planner)
GEMINI_API_KEY="your-gemini-api-key"

# ─── Headless WordPress CMS for SEO (WordPress.com Free) ───
# Create free WordPress.com site: https://wordpress.com
# Endpoint: https://your-site.wordpress.com/wp-json/wp/v2
WORDPRESS_GRAPHQL_URL="https://booktheguide.wordpress.com/wp-json/wp/v2"
# WordPress Application Password (optional, for authenticated access)
WORDPRESS_AUTH_TOKEN=""
# Secrets for preview and revalidation
WORDPRESS_PREVIEW_SECRET="your-preview-secret"
REVALIDATION_SECRET="your-revalidation-secret"
