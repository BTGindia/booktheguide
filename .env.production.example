# === Vercel Environment Variables ===
# Set these in Vercel Dashboard > Settings > Environment Variables
# DO NOT commit actual values to git

# Database (Supabase PostgreSQL — use pooling/transaction URL for serverless)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_URL="https://www.booktheguide.com"
NEXTAUTH_SECRET="<generate with: openssl rand -base64 32>"

# Public
NEXT_PUBLIC_APP_URL="https://www.booktheguide.com"

# Gemini AI (for NEEV travel assistant)
GEMINI_API_KEY="<your-google-ai-api-key>"

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
