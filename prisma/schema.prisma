generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String?
  name                String
  phone               String?
  role                UserRole             @default(CUSTOMER)
  image               String?
  isActive            Boolean              @default(true)
  emailVerified       DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  adminProfile        AdminProfile?
  aiQueryLogs         AiQueryLog[]
  bookings            Booking[]            @relation("CustomerBookings")
  guideManagerProfile GuideManagerProfile?
  guideProfile        GuideProfile?
  inspirationContent  InspirationContent[]
  reviews             Review[]
  sessions            Session[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AdminProfile {
  id                 String           @id @default(cuid())
  userId             String           @unique
  designation        String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedDepartures FixedDeparture[]
  reviewedProducts   Product[]
  managedStates      IndianState[]    @relation("AdminManagedStates")
}

model GuideManagerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  designation String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuideProfile {
  id                    String                      @id @default(cuid())
  userId                String                      @unique
  slug                  String                      @unique
  legalName             String?
  displayName           String?
  shortBio              String?
  bio                   String?
  tagline               String?
  addressLine           String?
  cityTown              String?
  district              String?
  addressState          String?
  country               String?                     @default("India")
  pincode               String?
  phone                 String?
  email                 String?
  gender                String?
  dateOfBirth           DateTime?
  maritalStatus         String?
  guideTypes            String[]
  experienceYears       Int?                        @default(0)
  maxAltitudeLed        Int?
  totalTrips            Int                         @default(0)
  averageRating         Float                       @default(0)
  totalReviews          Int                         @default(0)
  education             String?
  certifications        String[]
  languages             String[]
  specializations       String[]
  specializationProofs  Json                        @default("[]")
  certificationDocs     Json                        @default("[]")
  verificationStatus    GuideVerificationStatus     @default(UNVERIFIED)
  verificationNote      String?
  verifiedAt            DateTime?
  verifiedById          String?
  idType                String?
  idNumber              String?
  isVerified            Boolean                     @default(false)
  phoneVerified         Boolean                     @default(false)
  portfolioImages       String[]
  coverImage            String?
  termsAccepted         Boolean                     @default(false)
  termsAcceptedAt       DateTime?
  profileCompleteness   Int                         @default(0)
  isActive              Boolean                     @default(true)
  deactivatedAt         DateTime?
  guideScore            Float                       @default(0)
  scoreBreakdown        Json                        @default("{}")
  scoreUpdatedAt        DateTime?
  lastLoginAt           DateTime?
  complaintCount30d     Int                         @default(0)
  pendingReviewFields   String[]
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  auditLogs             AuditLog[]
  bookings              Booking[]                   @relation("GuideBookings")
  dataVersions          DataVersion[]
  availability          GuideAvailability[]
  guideCertifications   GuideCertification[]
  kyc                   GuideKyc?
  operatingDestinations GuideOperatingDestination[]
  operatingRegions      GuideOperatingRegion[]
  user                  User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceAreas          GuideServiceArea[]
  influencerPnLs        InfluencerPnL[]
  products              Product[]
  reviews               Review[]

  @@index([slug])
  @@index([averageRating])
  @@index([isActive, verificationStatus])
  @@index([verificationStatus])
  @@index([district])
  @@index([addressState])
  @@index([profileCompleteness])
  @@index([lastLoginAt])
}

model GuideServiceArea {
  id        String       @id @default(cuid())
  guideId   String
  stateId   String
  createdAt DateTime     @default(now())
  guide     GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)
  state     IndianState  @relation(fields: [stateId], references: [id])

  @@unique([guideId, stateId])
}

model GuideOperatingRegion {
  id        String       @id @default(cuid())
  guideId   String
  regionId  String
  createdAt DateTime     @default(now())
  guide     GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)
  region    Region       @relation(fields: [regionId], references: [id])

  @@unique([guideId, regionId])
  @@index([guideId])
}

model GuideOperatingDestination {
  id            String       @id @default(cuid())
  guideId       String
  destinationId String
  createdAt     DateTime     @default(now())
  destination   Destination  @relation(fields: [destinationId], references: [id])
  guide         GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([guideId, destinationId])
  @@index([guideId])
}

model GuideCertification {
  id                 String                 @id @default(cuid())
  guideId            String
  certType           String
  issuingAuthority   String
  certificateNumber  String?
  issueDate          DateTime?
  expiryDate         DateTime?
  documentUrl        String?
  documentType       String?
  verificationStatus CertVerificationStatus @default(PENDING)
  verifiedById       String?
  verifiedAt         DateTime?
  rejectionReason    String?
  expiryAlertSent60d Boolean                @default(false)
  expiryAlertSent30d Boolean                @default(false)
  expiryAlertSent7d  Boolean                @default(false)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  guide              GuideProfile           @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
  @@index([verificationStatus])
  @@index([expiryDate])
  @@index([certType])
  @@index([issuingAuthority])
}

model GuideKyc {
  id                   String       @id @default(cuid())
  guideId              String       @unique
  aadhaarLast4         String?
  aadhaarVerified      Boolean      @default(false)
  aadhaarDocumentUrl   String?
  panNumber            String?
  panVerified          Boolean      @default(false)
  panDocumentUrl       String?
  bankAccountEncrypted String?
  bankVerified         Boolean      @default(false)
  kycStatus            KycStatus    @default(NOT_SUBMITTED)
  payoutEligible       Boolean      @default(false)
  verifiedById         String?
  verifiedAt           DateTime?
  rejectionReason      String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  guide                GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([kycStatus])
  @@index([payoutEligible])
}

model DataVersion {
  id           String        @id @default(cuid())
  entityType   String
  entityId     String
  guideId      String?
  fieldName    String
  oldValue     String?
  newValue     String?
  changedById  String
  changeReason String?
  createdAt    DateTime      @default(now())
  guide        GuideProfile? @relation(fields: [guideId], references: [id])

  @@index([entityType, entityId])
  @@index([guideId])
  @@index([createdAt])
}

model AuditLog {
  id              String        @id @default(cuid())
  guideId         String?
  entityType      String
  entityId        String
  action          String
  fieldName       String?
  oldValue        String?
  newValue        String?
  reason          String?
  performedById   String
  performedByName String?
  createdAt       DateTime      @default(now())
  guide           GuideProfile? @relation(fields: [guideId], references: [id])

  @@index([guideId])
  @@index([entityType, entityId])
  @@index([performedById])
  @@index([createdAt])
  @@index([action])
}

model MediaReviewQueue {
  id              String              @id @default(cuid())
  entityType      String
  entityId        String
  mediaUrl        String
  mediaType       String
  context         String
  status          MediaApprovalStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime            @default(now())

  @@index([status])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model IndianState {
  id                  String                 @id @default(cuid())
  name                String                 @unique
  code                String                 @unique
  isNorthIndia        Boolean                @default(false)
  commissionPercent   Float                  @default(15)
  isActive            Boolean                @default(true)
  createdAt           DateTime               @default(now())
  categoryCommissions CategoryCommission[]
  cities              City[]
  corporateInquiries  CorporateTripInquiry[]
  serviceAreas        GuideServiceArea[]
  regions             Region[]
  admins              AdminProfile[]         @relation("AdminManagedStates")

  @@index([isNorthIndia])
}

model City {
  id           String        @id @default(cuid())
  name         String
  stateId      String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  state        IndianState   @relation(fields: [stateId], references: [id])
  destinations Destination[]

  @@unique([name, stateId])
  @@index([stateId])
}

model Region {
  id           String                 @id @default(cuid())
  name         String
  stateId      String
  description  String?
  coverImage   String?
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  guideRegions GuideOperatingRegion[]
  state        IndianState            @relation(fields: [stateId], references: [id])

  @@unique([name, stateId])
  @@index([stateId])
}

model Destination {
  id                String                      @id @default(cuid())
  name              String
  cityId            String
  description       String?
  altitude          Int?
  bestMonths        String[]
  openMonths        String[]
  avoidMonths       String[]
  coverImage        String?
  images            String[]
  isActive          Boolean                     @default(true)
  createdAt         DateTime                    @default(now())
  city              City                        @relation(fields: [cityId], references: [id])
  guideDestinations GuideOperatingDestination[]
  products          Product[]

  @@unique([name, cityId])
  @@index([cityId])
}

model Product {
  id                 String           @id @default(cuid())
  guideId            String
  destinationId      String
  title              String
  slug               String           @unique
  overview           String?
  description        String
  whatsIncluded      String[]
  whatsNotIncluded   String[]
  whatToBring        String[]
  highlights         String[]
  activityType       String           @default("TREKKING")
  packageCategory    String           @default("TOURIST_GUIDES")
  difficultyLevel    String           @default("MODERATE")
  durationDays       Int
  durationNights     Int
  minGroupSize       Int?             @default(1)
  maxGroupSize       Int?             @default(15)
  isPetFriendly      Boolean          @default(false)
  itinerary          Json             @default("[]")
  inclusions         String[]
  exclusions         String[]
  cancellationPolicy Json             @default("[]")
  minAge             Int?
  maxAge             Int?
  packageLanguages   String[]
  bestSeasonMonths   String[]
  coverImage         String?
  images             String[]
  status             ProductStatus    @default(DRAFT)
  reviewedById       String?
  reviewNotes        String?
  reviewedAt         DateTime?
  isTrending         Boolean          @default(false)
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  aiQueryLogs        AiQueryLog[]
  bookings           Booking[]
  fixedDepartures    FixedDeparture[]
  influencerPnLs     InfluencerPnL[]
  packageMedia       PackageMedia[]
  packagePricing     PackagePricing[]
  destination        Destination      @relation(fields: [destinationId], references: [id])
  guide              GuideProfile     @relation(fields: [guideId], references: [id], onDelete: Cascade)
  reviewedBy         AdminProfile?    @relation(fields: [reviewedById], references: [id])

  @@index([guideId])
  @@index([destinationId])
  @@index([slug])
  @@index([status])
  @@index([difficultyLevel])
  @@index([packageCategory])
  @@index([activityType])
}

model PackageMedia {
  id              String              @id @default(cuid())
  productId       String
  mediaUrl        String
  mediaType       String              @default("image")
  sequenceOrder   Int                 @default(0)
  caption         String?
  uploadDate      DateTime            @default(now())
  approvalStatus  MediaApprovalStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  product         Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([approvalStatus])
  @@index([sequenceOrder])
}

model PackagePricing {
  id         String   @id @default(cuid())
  productId  String
  label      String   @default("Standard")
  basePrice  Float
  startMonth String?
  endMonth   String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model PackageDiscount {
  id            String    @id @default(cuid())
  productId     String
  label         String
  discountType  String
  discountValue Float
  minGroupSize  Int?
  validFrom     DateTime?
  validUntil    DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([productId])
  @@index([isActive])
}

model FixedDeparture {
  id                String          @id @default(cuid())
  productId         String
  startDate         DateTime
  endDate           DateTime
  totalSeats        Int
  bookedSeats       Int             @default(0)
  maxGroupSize      Int             @default(15)
  minGroupSize      Int             @default(1)
  genderPolicy      String          @default("MIXED")
  pricingTiers      Json            @default("{}")
  pricePerPerson    Float           @default(0)
  petPricing        Json            @default("{}")
  commissionPercent Float?
  cgstPercent       Float           @default(2.5)
  sgstPercent       Float           @default(2.5)
  meetingPoint      String?
  endingPoint       String?
  meetingTime       String?
  notes             String?
  approvalStatus    DepartureStatus @default(PENDING_APPROVAL)
  reviewedById      String?
  reviewNotes       String?
  reviewedAt        DateTime?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  bookings          Booking[]
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviewedBy        AdminProfile?   @relation(fields: [reviewedById], references: [id])

  @@index([productId])
  @@index([startDate])
  @@index([isActive])
  @@index([approvalStatus])
}

model GuideAvailability {
  id          String       @id @default(cuid())
  guideId     String
  date        DateTime     @db.Date
  isAvailable Boolean      @default(true)
  notes       String?
  createdAt   DateTime     @default(now())
  guide       GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([guideId, date])
  @@index([guideId])
  @@index([date])
  @@index([isAvailable])
}

model Booking {
  id                 String          @id @default(cuid())
  bookingNumber      String          @unique
  customerId         String
  guideId            String
  tripType           TripType
  fixedDepartureId   String?
  productId          String?
  startDate          DateTime?
  endDate            DateTime?
  numberOfGuests     Int             @default(1)
  guestDetails       Json?
  meetingPoint       String?
  destinationName    String?
  requirements       Json?
  packageDetails     Json?
  baseAmount         Float
  commissionAmount   Float           @default(0)
  cgstAmount         Float           @default(0)
  sgstAmount         Float           @default(0)
  totalAmount        Float
  status             BookingStatus   @default(PENDING)
  specialRequests    String?
  cancelledAt        DateTime?
  cancellationReason String?
  refundAmount       Float?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  customer           User            @relation("CustomerBookings", fields: [customerId], references: [id])
  fixedDeparture     FixedDeparture? @relation(fields: [fixedDepartureId], references: [id])
  guide              GuideProfile    @relation("GuideBookings", fields: [guideId], references: [id])
  product            Product?        @relation(fields: [productId], references: [id])
  review             Review?

  @@index([customerId])
  @@index([guideId])
  @@index([bookingNumber])
  @@index([status])
  @@index([tripType])
}

model Review {
  id                  String       @id @default(cuid())
  bookingId           String?      @unique
  guideId             String
  customerId          String
  overallRating       Int
  knowledgeRating     Int?
  communicationRating Int?
  valueForMoneyRating Int?
  safetyRating        Int?
  comment             String?
  isAdminReview       Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  booking             Booking?     @relation(fields: [bookingId], references: [id])
  customer            User         @relation(fields: [customerId], references: [id])
  guide               GuideProfile @relation(fields: [guideId], references: [id])

  @@index([guideId])
  @@index([customerId])
}

model PlatformSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model CorporateTripInquiry {
  id               String       @id @default(cuid())
  organizationType String
  organizationName String
  contactName      String
  officialEmail    String
  phone            String
  groupSize        Int
  preferredStateId String?
  approxDays       Int
  additionalNotes  String?
  isResolved       Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  preferredState   IndianState? @relation(fields: [preferredStateId], references: [id])

  @@index([isResolved])
  @@index([createdAt])
}

model InspirationContent {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  type          String
  content       String?
  embedUrl      String?
  thumbnail     String?
  excerpt       String?
  tags          String[]
  destinations  String[]
  activityTypes String[]
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  authorId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  author        User      @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([type])
  @@index([isPublished])
  @@index([createdAt])
}

model PageConfig {
  id          String   @id @default(cuid())
  pageSlug    String   @unique
  config      Json     @default("{}")
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pageSlug])
}

model PageContent {
  id          String   @id @default(cuid())
  pageType    String
  entityId    String?
  entityName  String?
  content     Json     @default("{}")
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pageType, entityId])
  @@index([pageType])
  @@index([entityId])
}

model FAQ {
  id          String   @id @default(cuid())
  question    String
  answer      String
  category    String
  entityId    String?
  entityName  String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([entityId])
  @@index([isPublished])
}

model AiQueryLog {
  id               String   @id @default(cuid())
  userId           String?
  sessionId        String
  query            String
  response         String
  clickedPackageId String?
  responseTimeMs   Int?
  emotionalTone    String?
  travelStyle      String?
  intentSignal     String?
  suggestedIds     String[]
  createdAt        DateTime @default(now())
  clickedPackage   Product? @relation(fields: [clickedPackageId], references: [id])
  user             User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([emotionalTone])
  @@index([intentSignal])
}

model ExperienceCategory {
  id            String               @id @default(cuid())
  slug          String               @unique
  label         String
  urlSlug       String               @unique
  image         String?
  description   String?
  isEnabled     Boolean              @default(true)
  showInNav     Boolean              @default(false)
  navLabel      String?
  navOrder      Int                  @default(0)
  sortOrder     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  commissions   CategoryCommission[]
  subCategories SubCategory[]

  @@index([isEnabled])
  @@index([sortOrder])
}

model SubCategory {
  id          String               @id @default(cuid())
  categoryId  String
  name        String
  slug        String
  isEnabled   Boolean              @default(true)
  sortOrder   Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  commissions CategoryCommission[]
  category    ExperienceCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
  @@index([isEnabled])
}

model CategoryCommission {
  id                String              @id @default(cuid())
  stateId           String
  categoryId        String?
  subCategoryId     String?
  commissionPercent Float
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  category          ExperienceCategory? @relation(fields: [categoryId], references: [id])
  state             IndianState         @relation(fields: [stateId], references: [id])
  subCategory       SubCategory?        @relation(fields: [subCategoryId], references: [id])

  @@unique([stateId, categoryId, subCategoryId])
  @@index([stateId])
  @@index([categoryId])
}

model SponsoredItem {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  rank       Int      @default(0)
  context    String   @default("both")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId])
  @@index([entityType, isActive])
  @@index([rank])
}

model HomepageSelection {
  id         String   @id @default(cuid())
  section    String
  entityType String
  entityId   String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([section, entityType, entityId])
  @@index([section, isActive])
  @@index([sortOrder])
}

model InfluencerPnL {
  id                 String       @id @default(cuid())
  guideId            String
  productId          String?
  contractType       String       @default("COMMISSION")
  profitSharePercent Float?
  onlineSaleAmount   Float        @default(0)
  onlineSalePersons  Int          @default(0)
  offlineSaleAmount  Float        @default(0)
  offlineSalePersons Int          @default(0)
  totalCostAmount    Float        @default(0)
  totalRevenue       Float        @default(0)
  totalProfit        Float        @default(0)
  influencerShare    Float        @default(0)
  platformShare      Float        @default(0)
  notes              String?
  period             String?
  isFinalized        Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  guide              GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)
  product            Product?     @relation(fields: [productId], references: [id])

  @@index([guideId])
  @@index([productId])
  @@index([isFinalized])
}

model GuideTermsConditions {
  id        String   @id @default(cuid())
  title     String
  content   String
  state     String?
  guideType String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state, guideType])
  @@index([isActive])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  GUIDE_MANAGER
  GUIDE
  CUSTOMER
  UI_MANAGER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  AWAITING_QUOTE
  QUOTE_SENT
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
